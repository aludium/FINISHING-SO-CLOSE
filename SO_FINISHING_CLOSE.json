                  {
                      "parameters":  {
                                         "operation":  "execute",
                                         "query":  "=DECLARE\n   v_order_no_ VARCHAR2(32000) := \u0027{{ $json.ORDER_NO }}\u0027;\n   v_attr_     VARCHAR2(32000) := \u0027\u0027;\n   p0_ VARCHAR2(32000) := \u0027{{ $json.ORDER_NO }}\u0027;\n   p1_ VARCHAR2(32000) := \u0027{{ $json.RELEASE_NO }}\u0027;\n   p2_ VARCHAR2(32000) := \u0027{{ $json.SEQUENCE_NO }}\u0027;\nBEGIN\n   IF v_order_no_ IS NOT NULL AND LENGTH(TRIM(v_order_no_)) \u003e 0 THEN\n      IFSAPP.Shop_Ord_API.Close_So_Under_Issue(v_attr_, p0_, p1_, p2_);\n   END IF;\nEND;",
