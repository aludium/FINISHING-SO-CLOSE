                                         "jsCode":  "const s = $getWorkflowStaticData(\u0027global\u0027);\nif (!Array.isArray(s.orders_cerradas)) s.orders_cerradas = [];\nfor (const item of items) {\n  if (item.json.ORDER_NO) {\n    s.orders_cerradas.push({ order_no: item.json.ORDER_NO, release_no: item.json.RELEASE_NO, sequence_no: item.json.SEQUENCE_NO });\n  }\n}\nreturn items;"
