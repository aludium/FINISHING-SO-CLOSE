                  {
                      "parameters":  {
                                         "jsCode":  "const s = $getWorkflowStaticData(\u0027global\u0027);\nif (!Array.isArray(s.lotes_recibidos)) s.lotes_recibidos = [];\nfor (const item of items) {\n  if (item.json.ORDER_NO) {\n    s.lotes_recibidos.push({ order_no: item.json.ORDER_NO, lote: item.json.LOTE, release_no: item.json.RELEASE_NO, sequence_no: item.json.SEQUENCE_NO, reserved_qty: item.json.RESERVED_QTY });\n  }\n}\nreturn items;"
