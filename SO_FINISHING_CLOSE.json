                  {
                      "parameters":  {
                                         "operation":  "execute",
                                         "query":  "=DECLARE\n   v_order_no_ VARCHAR2(32000) := \u0027{{ $json.ORDER_NO }}\u0027;\n   p0_  VARCHAR2(32000) := \u0027\u0027;\n   p1_  FLOAT;\n   p2_  VARCHAR2(32000) := \u0027{{ $json.ORDER_NO }}\u0027;\n   p3_  VARCHAR2(32000) := \u0027{{ $json.RELEASE_NO }}\u0027;\n   p4_  VARCHAR2(32000) := \u0027{{ $json.SEQUENCE_NO }}\u0027;\n   p5_  VARCHAR2(32000) := \u00271\u0027;\n   p6_  VARCHAR2(32000) := \u0027Yes\u0027;\n   p7_  VARCHAR2(32000) := \u0027No\u0027;\n   p8_  VARCHAR2(32000) := \u0027Shop Order\u0027;\n   p9_  FLOAT := NULL;\n   p10_ VARCHAR2(32000) := \u0027!\n$CONDITION_CODE=\n$LOCATION_NO=FG\n$LOT_BATCH_NO={{ $json.LOTE }}\n$WAIV_DEV_REJ_NO=\n$EXPIRATION_DATE=\n$AVAILABILITY_CONTROL_ID=\n$CATCH_QTY=0\n$RESERVED_QTY={{ $json.RESERVED_QTY }}\n\u0027;\n   p11_ VARCHAR2(32000) := \u0027No\u0027;\n   p12_ VARCHAR2(32000) := \u0027TRUE\u0027;\nBEGIN\n   IF v_order_no_ IS NOT NULL AND LENGTH(TRIM(v_order_no_)) \u003e 0 THEN\n      SELECT IFSAPP.Inventory_Putaway_Manager_API.Get_Next_Putaway_Event_Id INTO p1_ FROM DUAL;\n      IFSAPP.Shop_Ord_Util_API.Receive_Lots_In_Message__(p0_, p1_, p2_, p3_, p4_, p5_, p6_, p7_, p8_, p9_, p10_, p11_, p12_);\n   END IF;\nEND;",
                                         "poolOptions":  {

                                                         }
                                     },
