                  {
                      "parameters":  {
                                         "jsCode":  "const s = $getWorkflowStaticData(\u0027global\u0027);\nconst lotes = s.lotes_recibidos || [];\nconst orders = s.orders_cerradas || [];\nlet msg = \u0027RESUMEN SO_FINISHING_CLOSE\\n==============================\\n\\n\u0027;\nmsg += `LOTES RECIBIDOS (${lotes.length}):\\n------------------------------\\n`;\nif (!lotes.length) msg += \u0027  Sin lotes pendientes\\n\u0027;\nelse for (const l of lotes) msg += `  ORDER_NO: ${l.order_no} | LOTE: ${l.lote} | QTY: ${l.reserved_qty}\\n`;\nmsg += `\\nORDERS CERRADAS (${orders.length}):\\n------------------------------\\n`;\nif (!orders.length) msg += \u0027  Sin orders para cerrar\\n\u0027;\nelse for (const o of orders) msg += `  ORDER_NO: ${o.order_no}\\n`;\nreturn [{ json: { resumen: msg, num_lotes: lotes.length, num_orders: orders.length } }];"
