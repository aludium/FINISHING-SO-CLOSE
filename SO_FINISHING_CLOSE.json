                      "name":  "When clicking \u0027Execute workflow\u0027"
                  },
                  {
                      "parameters":  {
                                         "query":  "SELECT\n    so.order_no,\n    so.release_no,\n    so.sequence_no,\n    so.contract,\n    so.part_no,\n    rlb.lote,\n    so.qty_complete,\n    NVL(rlb.numero_de_lotes, 0) AS numero_de_lotes,\n    NVL(rlb.reserved_qty, 0)    AS reserved_qty,\n    NVL(wc.num_wc_no_90, 0)     AS num_work_center_no_no_90\nFROM ifsapp.shop_ord so\nLEFT JOIN (\n    SELECT\n        lot_batch_no AS lote,\n        order_ref1   AS order_no,\n        order_ref2   AS release_no,\n        order_ref3   AS sequence_no,\n        COUNT(*)        AS numero_de_lotes,\n        SUM(reserved_qty) AS reserved_qty\n    FROM ifsapp.reserved_lot_batch\n    GROUP BY\n        order_ref1, order_ref2, order_ref3, lot_batch_no\n) rlb\n  ON rlb.order_no    = so.order_no\n AND rlb.release_no  = so.release_no\n AND rlb.sequence_no = so.sequence_no\nLEFT JOIN (\n    SELECT\n        order_no, release_no, sequence_no,\n        COUNT(*) AS num_wc_no_90\n    FROM ifsapp.shop_order_operation\n    WHERE oper_status_code_db \u003c\u003e 90\n    GROUP BY order_no, release_no, sequence_no\n) wc\n  ON wc.order_no    = so.order_no\n AND wc.release_no  = so.release_no\n AND wc.sequence_no = so.sequence_no\nWHERE so.contract = \u0027AMO\u0027\n  AND so.state    = \u0027Started\u0027\n  AND so.part_no \u003c\u003e \u0027COMBIITEM\u0027\n  AND so.qty_complete = 0\n  AND EXISTS (\n        SELECT 1 FROM ifsapp.shop_order_operation op\n        WHERE op.order_no    = so.order_no\n          AND op.release_no  = so.release_no\n          AND op.sequence_no = so.sequence_no\n          AND op.work_center_no = \u0027LAB\u0027\n          AND op.oper_status_code_db = 90\n      )\n  AND EXISTS (\n        SELECT 1 FROM ifsapp.shop_order_operation op\n        WHERE op.order_no    = so.order_no\n          AND op.release_no  = so.release_no\n          AND op.sequence_no = so.sequence_no\n          AND op.work_center_no = \u0027QINSP\u0027\n          AND op.oper_status_code_db = 90\n      )\n  AND EXISTS (\n        SELECT 1 FROM ifsapp.shop_order_operation op\n        WHERE op.order_no    = so.order_no\n          AND op.release_no  = so.release_no\n          AND op.sequence_no = so.sequence_no\n          AND op.work_center_no = \u0027EMB\u0027\n          AND op.oper_status_code_db = 90\n      )\n  AND NOT EXISTS (\n        SELECT 1 FROM ifsapp.shop_order_operation op\n        WHERE op.order_no    = so.order_no\n          AND op.release_no  = so.release_no\n          AND op.sequence_no = so.sequence_no\n          AND op.work_center_no LIKE \u0027SBB%\u0027\n      )\n  AND EXISTS (\n        SELECT 1 FROM ifsapp.reserved_lot_batch rlb2\n        WHERE rlb2.order_ref1   = so.order_no\n          AND rlb2.order_ref2   = so.release_no\n          AND rlb2.order_ref3   = so.sequence_no\n          AND rlb2.c_total_tare \u003e 0\n      )",
                                         "poolOptions":  {

                                                         }
                                     },
